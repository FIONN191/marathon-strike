{
  "name": "marathon-strike",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5190 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 5191",
    "app:start": "electron .",
    "dist": "vite build && electron-builder --mac --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.fionnleo.marathon-loststarship",
    "productName": "Marathon 失落星船",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asar": true,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": null,
      "category": "public.app-category.games",
      "artifactName": "Marathon-LostStarship-${version}-mac.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "MarathonLostStarship",
      "artifactName": "Marathon-LostStarship-Setup-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
